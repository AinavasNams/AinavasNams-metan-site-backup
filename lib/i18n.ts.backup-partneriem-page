// ---------------------------------------------------------------------------
// Helper: resolve a dot-notated key against the nested translations object
// ---------------------------------------------------------------------------
export function getTranslation(key: string, lang: Language = 'lv'): string {
  const resolve = (obj: any, path: string): string | undefined => {
    const parts = path.split('.');
    let current = obj;
    for (const part of parts) {
      if (current && typeof current === 'object' && part in current) {
        current = current[part];
      } else {
        return undefined;
      }
    }
    return typeof current === 'string' ? current : undefined;
  };

  // Try requested language first, then fall back to default (lv)
  return resolve(translations[lang], key)
    ?? resolve(translations[defaultLocale], key)
    ?? key;
}

// Convenience: return full translation object for a locale
export function getTranslations(locale: Locale) {
  return translations[locale] || translations[defaultLocale];
}
