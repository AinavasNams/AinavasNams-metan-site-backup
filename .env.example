# 🚀 METAN.LV МАКСИМАЛЬНАЯ АВТОМАТИЗАЦИЯ
# Скопируйте этот файл в .env.local и заполните значения

# ==========================================
# 🎯 ОСНОВНЫЕ НАСТРОЙКИ
# ==========================================
NEXT_PUBLIC_SITE_URL=https://metan.lv
NEXT_PUBLIC_SITE_NAME="METAN.LV - Biometāna ražošana"
NEXT_PUBLIC_CONTACT_EMAIL=tsv@metan.lv
NEXT_PUBLIC_CONTACT_PHONE="+371 27727724"

# ==========================================
# 📊 GOOGLE ANALYTICS & GTM
# ==========================================
NEXT_PUBLIC_GA_ID=G-METAN2025AN
NEXT_PUBLIC_GTM_ID=GTM-METAN-LV
NEXT_PUBLIC_GOOGLE_SEARCH_CONSOLE_ID=XXXXXXXXXX

# ==========================================
# 🗺️ GOOGLE MAPS - КРИТИЧЕСКИ ВАЖНО!
# ==========================================
# Google Maps API ключ для поиска городов в калькуляторе
# 
# ВАЖНО для Production:
# 1. Получите API ключ в Google Cloud Console
# 2. Включите следующие API:
#    - Maps JavaScript API
#    - Places API  
#    - Geocoding API
# 3. В настройках API ключа добавьте домены:
#    - metan.lv/*
#    - *.metan.lv/*
#    - localhost:3000/* (для разработки)
# 4. На Vercel/Netlify добавьте переменную окружения:
#    NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_actual_api_key
#
# Если API недоступен, система автоматически переключится в offline режим
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyDsJl13dIA2mgNl3tzq0k9WS0tRRsDl7xU

# Координаты главного офиса (для карты контактов)
NEXT_PUBLIC_COMPANY_LAT=56.48078918457031
NEXT_PUBLIC_COMPANY_LNG=23.057313919067383

# Серверный API ключ для расчета расстояний (только для бэкенда)
GOOGLE_MAPS_SERVER_API_KEY=AIzaSyDoLZcmarhFa8g35-k7b2UDRncyTCnMBvc

# ==========================================
# 📧 EMAIL AUTOMATION
# ==========================================
# Resend (Рекомендуется - современный и надежный)
RESEND_API_KEY=re_XXXXXXXXXX

# SMTP (альтернатива)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@metan.lv

# SendGrid (альтернатива SMTP)
SENDGRID_API_KEY=SG.XXXXXXXXXX

# ==========================================
# 🏭 ЦИФРОВОЙ ЗАВОД АВТОМАТИЗАЦИЯ
# ==========================================
# n8n Workflow Automation
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/lead-processing
NEXT_PUBLIC_N8N_API_KEY=XXXXXXXXXX

# Zapier интеграция (альтернатива n8n)
NEXT_PUBLIC_ZAPIER_WEBHOOK=https://hooks.zapier.com/hooks/catch/XXXXXXXXXX/

# Telegram уведомления для срочных лидов
NEXT_PUBLIC_TELEGRAM_BOT_TOKEN=XXXXXXXXXX:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_TELEGRAM_CHAT_ID=-XXXXXXXXXX

# ==========================================
# 🔗 CRM ИНТЕГРАЦИЯ
# ==========================================
# Google Sheets (рекомендуется для простоты)
NEXT_PUBLIC_GOOGLE_SHEETS_DOCUMENTS_WEBHOOK=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
NEXT_PUBLIC_GOOGLE_SHEETS_CONTACTS_WEBHOOK=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# HubSpot (профессиональная CRM)
NEXT_PUBLIC_HUBSPOT_API_KEY=XXXXXXXXXX
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=XXXXXXXXXX

# Salesforce (энтерпрайз CRM)
NEXT_PUBLIC_SALESFORCE_API_URL=https://your-instance.salesforce.com
NEXT_PUBLIC_SALESFORCE_API_KEY=XXXXXXXXXX

# ==========================================
# 🌐 СОЦИАЛЬНЫЕ СЕТИ
# ==========================================
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/metan.lv
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/company/metan-lv
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/metan.lv
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/metan_lv

# ==========================================
# 🚀 АВТОМАТИЗАЦИЯ ПРОДАЖ
# ==========================================
# Webhook для уведомлений о новых лидах
NEXT_PUBLIC_LEAD_NOTIFICATION_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Slack интеграция для команды
NEXT_PUBLIC_SLACK_WEBHOOK=https://hooks.slack.com/services/XXXXXXXXXX
NEXT_PUBLIC_SLACK_CHANNEL=#leads

# Microsoft Teams интеграция
NEXT_PUBLIC_TEAMS_WEBHOOK=https://your-org.webhook.office.com/webhookb2/XXXXXXXXXX

# ==========================================
# 🔒 БЕЗОПАСНОСТЬ
# ==========================================
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=https://metan.lv

# ==========================================
# 🛠️ РАЗРАБОТКА
# ==========================================
NODE_ENV=production
ANALYZE=false

# ==========================================
# 💡 ДОПОЛНИТЕЛЬНЫЕ ИНТЕГРАЦИИ
# ==========================================
